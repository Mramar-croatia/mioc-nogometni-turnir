rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /tournament/{id} {
      allow read;
      allow write: if isAdmin();
    }

    match /teams/{id} {
      allow read;
      allow write: if isAdmin();
    }

    match /matches/{id} {
      allow read;
      allow write: if isAdmin();

      match /goals/{goalId} {
        allow read;
        allow write: if isAdmin();
      }
    }

    match /brackets/{id} {
      allow read;
      allow write: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
